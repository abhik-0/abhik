{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores student profile information for personalization.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "academicBackground": { "type": "string", "description": "The student's academic background." },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "List of student's skills." },
        "preferences": { "type": "array", "items": { "type": "string" }, "description": "List of student's preferences." }
      },
      "required": ["uid"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Stores chat history for a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "messages"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/conversations/{uid}": {
      "schema": "Conversation",
      "description": "User conversation history document."
    }
  }
}
